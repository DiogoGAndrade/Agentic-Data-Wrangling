{
  "actions": [
    {
      "action": "select_features",
      "target_columns": ["education"],
      "params": {
        "drop_columns": ["education"]
      }
    },
    {
      "action": "add_missing_indicators",
      "target_columns": ["workclass", "occupation", "native_country"],
      "params": {
        "min_na_rate": 0.05,
        "max_indicators": 10
      }
    },
    {
      "action": "handle_missing",
      "target_columns": ["workclass", "occupation"],
      "params": {
        "strategy": "most_frequent"
      }
    },
    {
      "action": "handle_missing",
      "target_columns": ["native_country"],
      "params": {
        "strategy": "most_frequent"
      }
    },
    {
      "action": "group_rare_categories",
      "target_columns": ["native_country", "workclass", "occupation"],
      "params": {
        "min_frequency_pct": 0.01,
        "replacement_label": "Other"
      }
    },
    {
      "action": "clip_outliers",
      "target_columns": ["capital_gain", "capital_loss", "fnlwgt", "hours_per_week"],
      "params": {
        "method": "iqr",
        "iqr_k": 1.5
      }
    },
    {
      "action": "transform_numeric_skewed",
      "target_columns": ["capital_gain", "capital_loss", "fnlwgt"],
      "params": {
        "skewness_threshold": 0.75,
        "method": "log1p",
        "model_family": "linear"
      }
    },
    {
      "action": "encode_categorical_per_column",
      "target_columns": ["workclass", "education_num", "marital_status", "occupation", "relationship", "race", "sex", "native_country"],
      "params": {
        "column_encodings": {
          "education_num": "ordinal",
          "marital_status": "ordinal",
          "relationship": "one_hot",
          "race": "one_hot",
          "sex": "one_hot",
          "workclass": "one_hot",
          "occupation": "one_hot",
          "native_country": "one_hot"
        },
        "default_method": "one_hot"
      }
    }
  ]
}